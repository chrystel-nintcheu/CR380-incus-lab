#!/usr/bin/env bash
# =============================================================================
# CR380 - Incus Lab Test Suite — Configuration
# Configuration centrale / Central configuration
#
# FR: Modifier ce fichier pour mettre à jour les versions d'images, les noms
#     d'alias et les délais d'attente avant chaque session de cours.
# EN: Edit this file to update image versions, alias names, and timeouts
#     before each class session.
# =============================================================================

# -----------------------------------------------------------------------------
# Images distantes / Remote images
# FR: Noms complets des images dans le registre distant (images:)
# EN: Full image names from the remote registry (images:)
# -----------------------------------------------------------------------------
IMAGE_UBUNTU="images:ubuntu/noble/amd64"
IMAGE_ALPINE="images:alpine/3.20"
IMAGE_OPENWRT="images:openwrt/23.05/amd64"
IMAGE_DEBIAN="images:debian/12"

# -----------------------------------------------------------------------------
# Alias locaux / Local aliases
# FR: Noms courts attribués aux images téléchargées sur l'hôte local
# EN: Short names assigned to images downloaded to the local host
# -----------------------------------------------------------------------------
ALIAS_UBUNTU="ubuntux64"
ALIAS_ALPINE="alpinex64"
ALIAS_OPENWRT="openwrt23.05"
ALIAS_DEBIAN="debian12"

# -----------------------------------------------------------------------------
# Noms de conteneurs / Container names
# FR: Noms utilisés dans les labs pour identifier les conteneurs
# EN: Names used in lab exercises to identify containers
# -----------------------------------------------------------------------------
CT_U1="u1"
CT_CLONE="cloneU1x64"
CT_ROUTER="routerCT"
CT_DEBIAN="debianCT"
CT_NGINX="nginxCT"
CT_APPWEB="appwebCT"

# -----------------------------------------------------------------------------
# Noms d'images publiées / Published image names
# FR: Alias des images créées à partir de conteneurs pendant les labs
# EN: Aliases for images published from containers during labs
# -----------------------------------------------------------------------------
IMG_CUSTOM_U1="imgCustomU1x64"
IMG_NGINX="nginx-0.0.0"
IMG_DEMO_APP="demo-app-0.0.0"

# -----------------------------------------------------------------------------
# Initialisation / Initialization
# FR: Paramètres utilisés lors de 'incus admin init'
# EN: Parameters used during 'incus admin init'
# -----------------------------------------------------------------------------
STORAGE_POOL_NAME="cr380storagepool"
STORAGE_POOL_DRIVER="dir"
BRIDGE_NAME="cr380incusbr0"
BRIDGE_IPV4="auto"
BRIDGE_IPV6="none"

# -----------------------------------------------------------------------------
# Stockage et volumes / Storage and volumes
# FR: Noms pour le pool de stockage et volume créés dans les labs avancés
# EN: Names for the storage pool and volume created in advanced labs
# -----------------------------------------------------------------------------
ADV_STORAGE_POOL="websrv_storage"
ADV_STORAGE_DIR="websrv_dir"
ADV_VOLUME="www_volume"

# -----------------------------------------------------------------------------
# Ports exposés / Exposed ports
# FR: Ports utilisés pour les exercices de proxy
# EN: Ports used for proxy device exercises
# -----------------------------------------------------------------------------
PORT_OPENWRT_LISTEN="8888"
PORT_NGINX_LISTEN="8000"
PORT_APPWEB_LISTEN="8001"

# -----------------------------------------------------------------------------
# Dépôt Git de l'application de démonstration / Demo app Git repository
# FR: URL du dépôt cloné pour les exercices de transfert de fichiers
# EN: URL of the repository cloned for file transfer exercises
# -----------------------------------------------------------------------------
DEMO_APP_REPO="https://github.com/nintcheu/dog-breed-recognition.git"
DEMO_APP_DIR="ml-app"

# -----------------------------------------------------------------------------
# Délais d'attente (en secondes) / Timeouts (in seconds)
# FR: Augmenter ces valeurs si votre connexion Internet est lente
# EN: Increase these values if your Internet connection is slow
# -----------------------------------------------------------------------------
TIMEOUT_APT=900
TIMEOUT_DOWNLOAD=300
TIMEOUT_CONTAINER_READY=60
TIMEOUT_EXEC=180
TIMEOUT_DEFAULT=30
TIMEOUT_CURL=15

# -----------------------------------------------------------------------------
# Référence GitBook / GitBook reference
# FR: URL de base du guide de cours (pour les liens dans les messages)
# EN: Base URL of the course guide (for links in messages)
# -----------------------------------------------------------------------------
GITBOOK_BASE_URL="https://polytechnique-montreal.gitbook.io/cr380/uypezSjfF3TINgWe4QZx"

# -----------------------------------------------------------------------------
# Paramètres VM étudiants / Student VM parameters
# FR: Ressources allouées aux VM étudiants via multipass
# EN: Resources allocated to student VMs via multipass
# -----------------------------------------------------------------------------
VM_NAME="cr380-lab"
VM_CPUS=2
VM_MEMORY="4G"
VM_DISK="20G"
VM_IMAGE="24.04"
